<nav id="main-nav" class="fixed top-0 w-full z-50 glass-nav border-b border-[rgba(255,255,255,0.3)] shadow-[0_8px_32px_rgba(0,0,0,0.04)]">
  <div class="max-w-screen-xl mx-auto px-5 md:px-10 h-16 flex items-center justify-between gap-4">

    <!-- Logo -->
    <a href="/" class="font-extrabold text-xl text-primary tracking-tight flex-shrink-0">CampusBites</a>

    <!-- Search (desktop) -->
    <form action="/search" method="GET" class="hidden md:flex flex-1 max-w-md relative">
      <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-secondary text-lg">search</span>
      <input name="q" value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>"
        class="w-full h-10 pl-10 pr-4 bg-surface-container-low border-none rounded-xl text-sm font-medium focus:ring-2 focus:ring-primary/20 focus:bg-white outline-none placeholder:text-secondary/60 transition-all"
        placeholder="Search food, outlets..." />
    </form>

    <!-- Right actions -->
    <div class="flex items-center gap-2">
      <% if (typeof user !== 'undefined' && user) { %>

        <!-- Cart button (students only) -->
        <% if (user.role === 'student') { %>
        <button onclick="toggleCart()"
          class="relative w-10 h-10 rounded-full bg-surface-container-low flex items-center justify-center hover:bg-surface-container transition-colors">
          <span class="material-symbols-outlined text-on-surface text-[22px]">shopping_bag</span>
          <span id="cart-badge" class="absolute -top-1 -right-1 w-5 h-5 bg-primary text-on-primary text-[10px] font-extrabold rounded-full items-center justify-center hidden" style="display:none">0</span>
        </button>
        <% } %>

        <!-- User menu -->
        <div class="relative" id="user-menu-wrapper">
          <button onclick="toggleUserMenu()"
            class="flex items-center gap-2 px-3 py-2 rounded-full bg-surface-container-low hover:bg-surface-container transition-colors">
            <div class="w-7 h-7 rounded-full bg-primary-container flex items-center justify-center text-on-primary-container font-bold text-xs flex-shrink-0 overflow-hidden">
              <% if (user.pfp) { %>
                <img src="<%= user.pfp %>" alt="<%= user.name %>" class="w-full h-full object-cover" />
              <% } else { %>
                <%= user.name ? user.name[0].toUpperCase() : 'U' %>
              <% } %>
            </div>
            <span class="font-bold text-sm text-on-surface max-w-[120px] truncate">
              <%= user.name ? user.name.split(' ')[0] : 'User' %>
            </span>
            <span class="material-symbols-outlined text-secondary text-base">expand_more</span>
          </button>

          <div id="user-menu" class="hidden absolute right-0 top-full mt-2 w-52 bg-white rounded-2xl shadow-xl border border-outline-variant/20 py-2 z-50">
            <% if (user.role === 'student') { %>
              <a href="/outlets" class="flex items-center gap-3 px-4 py-2.5 text-sm text-on-surface hover:bg-surface-container-low transition-colors">
                <span class="material-symbols-outlined text-base text-secondary">storefront</span> Browse Outlets
              </a>
              <a href="/orders" class="flex items-center gap-3 px-4 py-2.5 text-sm text-on-surface hover:bg-surface-container-low transition-colors">
                <span class="material-symbols-outlined text-base text-secondary">receipt_long</span> My Orders
              </a>
              <a href="/profile" class="flex items-center gap-3 px-4 py-2.5 text-sm text-on-surface hover:bg-surface-container-low transition-colors">
                <span class="material-symbols-outlined text-base text-secondary">person</span> Profile
              </a>
            <% } else if (user.role === 'admin') { %>
              <a href="/admin" class="flex items-center gap-3 px-4 py-2.5 text-sm text-on-surface hover:bg-surface-container-low transition-colors">
                <span class="material-symbols-outlined text-base text-secondary">dashboard</span> Dashboard
              </a>
            <% } else if (user.role === 'superadmin') { %>
              <a href="/superadmin" class="flex items-center gap-3 px-4 py-2.5 text-sm text-on-surface hover:bg-surface-container-low transition-colors">
                <span class="material-symbols-outlined text-base text-secondary">admin_panel_settings</span> Super Admin
              </a>
            <% } %>
            <div class="h-px bg-outline-variant/20 my-1"></div>
            <button onclick="logout()" class="w-full flex items-center gap-3 px-4 py-2.5 text-sm text-error hover:bg-error-container/20 transition-colors text-left">
              <span class="material-symbols-outlined text-base">logout</span> Logout
            </button>
          </div>
        </div>

      <% } else { %>
        <a href="/login" class="font-bold text-sm text-secondary hover:text-primary transition-colors px-2">Login</a>
        <a href="/signup" class="bg-primary text-on-primary px-5 py-2 rounded-full font-bold text-sm hover:bg-primary/90 transition-colors shadow-sm">Sign Up</a>
      <% } %>
    </div>
  </div>
</nav>

<!-- ════════════════════════════════════════════
     CART SIDEBAR (students only)
═════════════════════════════════════════════ -->
<% if (typeof user !== 'undefined' && user && user.role === 'student') { %>

<!-- Backdrop -->
<div id="cart-overlay"
  class="fixed inset-0 bg-black/40 backdrop-blur-sm z-[60] hidden"
  onclick="toggleCart()"></div>

<!-- Drawer -->
<aside id="cart-drawer"
  class="fixed right-0 top-0 h-full w-full sm:w-[400px] z-[61] flex flex-col border-l border-outline-variant/20"
  style="background:rgba(248,249,250,0.97);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);box-shadow:0 0 60px rgba(0,0,0,0.12);transform:translateX(100%);transition:transform 0.32s cubic-bezier(0.16,1,0.3,1);">

  <!-- Header -->
  <div class="flex items-center justify-between px-6 py-5 border-b border-outline-variant/15">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-2xl bg-primary/10 flex items-center justify-center">
        <span class="material-symbols-outlined text-primary">shopping_bag</span>
      </div>
      <div>
        <h3 class="font-bold text-base text-on-surface">Your Cart</h3>
        <p class="text-secondary text-xs" id="cart-count-label">0 items</p>
      </div>
    </div>
    <div class="flex items-center gap-2">
      <button id="cart-clear-btn" onclick="clearCart()"
        style="display:none"
        class="text-secondary hover:text-error transition-colors font-bold text-xs px-3 py-1.5 rounded-lg hover:bg-error-container/20">
        Clear
      </button>
      <button onclick="toggleCart()"
        class="w-9 h-9 rounded-full hover:bg-surface-container-high flex items-center justify-center transition-colors">
        <span class="material-symbols-outlined text-secondary">close</span>
      </button>
    </div>
  </div>

  <!-- Items area -->
  <div class="flex-1 overflow-y-auto px-6 py-4">

    <!-- Empty state -->
    <div id="cart-empty-state" class="flex flex-col items-center justify-center h-full gap-5 text-center">
      <div class="w-24 h-24 bg-primary/5 rounded-3xl flex items-center justify-center">
        <span class="material-symbols-outlined text-5xl text-primary/20">shopping_bag</span>
      </div>
      <div>
        <p class="font-bold text-on-surface text-lg">Your cart is empty</p>
        <p class="text-secondary text-sm mt-1">Add items from an outlet to get started</p>
      </div>
      <button onclick="toggleCart()"
        class="bg-primary text-on-primary px-7 py-3 rounded-full font-bold text-sm shadow-md hover:shadow-lg active:scale-95 transition-all">
        Browse Outlets
      </button>
    </div>

    <!-- Items list -->
    <div id="cart-items-list" style="display:none" class="space-y-3"></div>
  </div>

  <!-- Footer: bill + checkout -->
  <div id="cart-footer" style="display:none"
    class="px-6 py-5 border-t border-outline-variant/15 space-y-4 bg-surface-container-low/50">

    <div class="space-y-2">
      <div class="flex justify-between text-sm">
        <span class="text-secondary font-medium">Subtotal</span>
        <span class="font-bold text-on-surface" id="bill-subtotal">₹0</span>
      </div>
      <div class="flex justify-between text-sm">
        <span class="text-secondary font-medium">GST (5%)</span>
        <span class="font-bold text-on-surface" id="bill-gst">₹0</span>
      </div>
      <div class="flex justify-between text-sm">
        <span class="text-secondary font-medium">Pickup fee</span>
        <span class="font-bold text-green-600">FREE</span>
      </div>
      <div class="flex justify-between border-t border-outline-variant/20 pt-2 mt-1">
        <span class="font-bold text-base text-on-surface">Total</span>
        <span class="font-extrabold text-xl text-primary" id="bill-total">₹0</span>
      </div>
    </div>

    <a href="/checkout" onclick="toggleCart()"
      class="w-full py-4 bg-primary text-on-primary rounded-2xl font-bold text-base shadow-[0_4px_12px_rgba(153,71,0,0.3)] hover:shadow-[0_8px_20px_rgba(153,71,0,0.4)] hover:-translate-y-0.5 active:scale-95 transition-all flex items-center justify-center gap-2">
      <span class="material-symbols-outlined">shopping_bag</span>
      Proceed to Checkout &middot; <span id="bill-total-btn">₹0</span>
    </a>

    <div class="flex items-center justify-center gap-2 text-secondary text-xs">
      <span class="material-symbols-outlined text-sm text-primary">lock</span>
      <span>Secure campus payment</span>
    </div>
  </div>
</aside>

<% } %>

<script>
// ── Cart open / close ─────────────────────────────────────────────
function toggleCart() {
  const drawer  = document.getElementById('cart-drawer');
  const overlay = document.getElementById('cart-overlay');
  if (!drawer) return;
  const isOpen = drawer.style.transform === 'translateX(0px)' || drawer.style.transform === 'translateX(0%)' || drawer.style.transform === 'none';
  if (isOpen) {
    drawer.style.transform  = 'translateX(100%)';
    overlay.classList.add('hidden');
  } else {
    drawer.style.transform  = 'translateX(0)';
    overlay.classList.remove('hidden');
    refreshCart();
  }
}

// ── Render cart data into sidebar ─────────────────────────────────
function renderCart(cartData) {
  const items    = cartData.items || [];
  const count    = items.reduce((s, i) => s + (i.quantity || 1), 0);
  const subtotal = items.reduce((s, i) => s + (i.price || 0) * (i.quantity || 1), 0);
  const gst      = Math.round(subtotal * 0.05);
  const total    = subtotal + gst;

  // ── Badge ──
  const badge = document.getElementById('cart-badge');
  if (badge) {
    badge.textContent = count;
    badge.style.display = count > 0 ? 'flex' : 'none';
  }

  // ── Count label & clear btn ──
  const lbl = document.getElementById('cart-count-label');
  if (lbl) lbl.textContent = `${items.length} item${items.length !== 1 ? 's' : ''}`;

  const clearBtn = document.getElementById('cart-clear-btn');
  if (clearBtn) clearBtn.style.display = items.length > 0 ? 'block' : 'none';

  // ── Empty / items toggle ──
  const emptyEl  = document.getElementById('cart-empty-state');
  const listEl   = document.getElementById('cart-items-list');
  const footerEl = document.getElementById('cart-footer');
  if (!emptyEl || !listEl || !footerEl) return;

  if (items.length === 0) {
    emptyEl.style.display  = 'flex';
    listEl.style.display   = 'none';
    footerEl.style.display = 'none';
    return;
  }

  emptyEl.style.display  = 'none';
  listEl.style.display   = 'block';
  footerEl.style.display = 'block';

  // ── Item cards ──
  listEl.innerHTML = items.map(item => {
    const mid = item.menuItemId || item._id;
    const qty = item.quantity || 1;
    return `
    <div class="flex items-center gap-4 bg-white rounded-2xl p-3 border border-outline-variant/10 shadow-sm">
      <div class="w-16 h-16 rounded-xl bg-primary/5 overflow-hidden flex-shrink-0">
        ${item.image
          ? `<img src="${item.image}" alt="${item.name||''}" class="w-full h-full object-cover"/>`
          : `<div class="w-full h-full flex items-center justify-center"><span class="material-symbols-outlined text-primary/30 text-2xl">lunch_dining</span></div>`}
      </div>
      <div class="flex-1 min-w-0">
        <h4 class="font-bold text-sm text-on-surface leading-tight" style="-webkit-line-clamp:1;display:-webkit-box;-webkit-box-orient:vertical;overflow:hidden">${item.name || 'Item'}</h4>
        <p class="font-bold text-primary text-sm mt-0.5">&#8377;${item.price || 0}</p>
      </div>
      <div class="flex items-center gap-2 flex-shrink-0">
        <button onclick="cartDecrement('${mid}', ${qty})"
          class="w-7 h-7 rounded-full bg-surface-container-high hover:bg-surface-container-highest flex items-center justify-center transition-colors active:scale-90">
          <span class="material-symbols-outlined text-sm">${qty > 1 ? 'remove' : 'delete'}</span>
        </button>
        <span class="font-bold text-sm text-on-surface w-5 text-center">${qty}</span>
        <button onclick="cartIncrement('${mid}', ${qty})"
          class="w-7 h-7 rounded-full bg-primary/10 hover:bg-primary/20 flex items-center justify-center transition-colors active:scale-90">
          <span class="material-symbols-outlined text-sm text-primary">add</span>
        </button>
      </div>
    </div>`;
  }).join('');

  // ── Bill ──
  document.getElementById('bill-subtotal').innerHTML  = `&#8377;${subtotal}`;
  document.getElementById('bill-gst').innerHTML       = `&#8377;${gst}`;
  document.getElementById('bill-total').innerHTML     = `&#8377;${total}`;
  document.getElementById('bill-total-btn').innerHTML = `&#8377;${total}`;
}

// ── API calls (cookie-based auth) ─────────────────────────────────
async function refreshCart() {
  try {
    const res  = await fetch('/api/cart', { credentials: 'include' });
    if (!res.ok) return;
    const data = await res.json();
    renderCart(data.data || data.cart || { items: [] });
  } catch { /* silent */ }
}

function cartIncrement(mid, qty) { cartUpdate(mid, qty + 1); }
function cartDecrement(mid, qty) {
  if (qty <= 1) cartRemove(mid);
  else cartUpdate(mid, qty - 1);
}

async function cartUpdate(menuItemId, quantity) {
  try {
    const res  = await fetch('/api/cart/update', {
      method: 'PUT',
      credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ menuItemId, quantity })
    });
    const data = await res.json();
    if (data.success) renderCart(data.data || data.cart || { items: [] });
    else showToast(data.message || 'Update failed', 'error');
  } catch { showToast('Error updating cart', 'error'); }
}

async function cartRemove(menuItemId) {
  try {
    const res  = await fetch('/api/cart/remove', {
      method: 'DELETE',
      credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ menuItemId })
    });
    const data = await res.json();
    if (data.success) renderCart(data.data || data.cart || { items: [] });
    else showToast(data.message || 'Remove failed', 'error');
  } catch { showToast('Error removing item', 'error'); }
}

async function clearCart() {
  try {
    const res  = await fetch('/api/cart/clear', {
      method: 'DELETE',
      credentials: 'include'
    });
    const data = await res.json();
    if (data.success) renderCart(data.data || { items: [] });
    else showToast(data.message || 'Clear failed', 'error');
  } catch { showToast('Error clearing cart', 'error'); }
}

// ── Global addToCart — called from outlet page ────────────────────
async function addToCart(menuItemId, btnEl) {
  if (btnEl) {
    btnEl.disabled = true;
    btnEl.innerHTML = '<div class="w-3 h-3 border-2 border-on-primary border-t-transparent rounded-full animate-spin"></div>';
  }
  try {
    const res  = await fetch('/api/cart/add', {
      method: 'POST',
      credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ menuItemId, quantity: 1 })
    });
    const data = await res.json();
    if (data.success) {
      showToast('Added to cart!', 'success');
      renderCart(data.data || data.cart || { items: [] });
    } else {
      showToast(data.message || 'Failed to add item', 'error');
    }
  } catch { showToast('Error adding to cart', 'error'); }
  if (btnEl) {
    btnEl.disabled = false;
    btnEl.innerHTML = '<span class="material-symbols-outlined text-sm">add</span>Add';
  }
}

// ── Auto-load badge on page load ──────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  if (document.getElementById('cart-badge')) refreshCart();
});
</script>