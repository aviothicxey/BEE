<%- include('../partials/head', { title: outlet ? outlet.name : 'Outlet' }) %>
<%- include('../partials/navbar') %>

<div class="bg-background min-h-screen pb-32">

  <% if (outlet) { %>

  <!-- Hero Banner -->
  <div class="relative h-72 md:h-96 overflow-hidden">

    <% if (outlet.image) { %>
      <img src="<%= outlet.image %>" alt="<%= outlet.name %>" class="w-full h-full object-cover" />
    <% } else { %>
      <div class="w-full h-full bg-gradient-to-br from-primary/20 to-tertiary/10 flex items-center justify-center">
        <span class="material-symbols-outlined text-9xl text-primary/15">storefront</span>
      </div>
    <% } %>

    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>

    <div class="absolute bottom-6 left-5 md:left-10 right-5 md:right-10">
      <div class="flex items-end justify-between">
        <div>
          <h1 class="font-extrabold text-3xl md:text-4xl text-white"><%= outlet.name %></h1>
          <% if (outlet.description) { %>
            <p class="text-white/80 text-sm mt-1"><%= outlet.description %></p>
          <% } %>
          <div class="flex items-center gap-4 mt-3 flex-wrap">
            <span class="flex items-center gap-1.5 text-white/90 text-xs font-bold">
              <span class="material-symbols-outlined text-sm">schedule</span>
              <%= outlet.timing || '10-15 min' %>
            </span>
            <span class="flex items-center gap-1.5 text-white/90 text-xs font-bold">
              <span class="material-symbols-outlined text-sm" style="font-variation-settings:'FILL' 1">star</span>
              4.8 rating
            </span>
            <span class="text-[10px] font-bold px-3 py-1 rounded-full <%= outlet.isSuspended ? 'bg-error/80 text-white' : 'bg-green-500/90 text-white' %>">
              <%= outlet.isSuspended ? 'Closed' : 'Open Now' %>
            </span>
          </div>
        </div>
        <a href="/outlets" class="w-10 h-10 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center text-white hover:bg-white/30 transition-colors flex-shrink-0">
          <span class="material-symbols-outlined">arrow_back</span>
        </a>
      </div>
    </div>

  </div>

  <main class="pt-8 pb-8 px-5 md:px-10 max-w-screen-xl mx-auto">

    <!-- Search -->
    <div class="mb-6 relative max-w-md">
      <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-secondary text-lg">search</span>
      <input id="menu-search" type="text" oninput="filterMenu(this.value)"
        class="w-full h-12 pl-11 pr-4 bg-surface-container-low border-none rounded-xl text-sm font-medium focus:ring-2 focus:ring-primary/20 focus:bg-white outline-none placeholder:text-secondary/60"
        placeholder="Search menu items..." />
    </div>

    <!-- Loading skeletons -->
    <div id="menu-loading" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
      <% for(let i=0;i<8;i++) { %>
      <div class="bg-white rounded-2xl overflow-hidden border border-outline-variant/10">
        <div class="h-48 shimmer"></div>
        <div class="p-4 space-y-2">
          <div class="h-4 shimmer rounded-full w-3/4"></div>
          <div class="h-3 shimmer rounded-full w-1/2"></div>
          <div class="h-6 shimmer rounded-full w-1/3 mt-3"></div>
        </div>
      </div>
      <% } %>
    </div>

    <!-- Available -->
    <div id="menu-available" class="hidden">
      <h2 class="font-bold text-base text-on-surface-variant uppercase tracking-wider mb-4 flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-green-500"></span>
        Available · <span id="available-count">0</span>
      </h2>
      <div id="available-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5 mb-10"></div>
    </div>

    <!-- Unavailable -->
    <div id="menu-unavailable" class="hidden opacity-60">
      <h2 class="font-bold text-base text-secondary uppercase tracking-wider mb-4">
        Unavailable · <span id="unavailable-count">0</span>
      </h2>
      <div id="unavailable-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5"></div>
    </div>

    <!-- Empty -->
    <div id="menu-empty" class="hidden text-center py-20">
      <span class="material-symbols-outlined text-4xl text-primary/20 block mb-2">restaurant_menu</span>
      <p class="font-bold text-on-surface">No menu items found</p>
    </div>

  </main>

  <% } else { %>

  <div class="flex items-center justify-center min-h-screen">
    <div class="text-center">
      <span class="material-symbols-outlined text-5xl text-primary/20 block mb-3">store_mall_directory</span>
      <p class="font-bold text-on-surface">Outlet not found</p>
      <a href="/outlets" class="mt-4 text-primary font-bold text-sm hover:underline block">← Back to outlets</a>
    </div>
  </div>

  <% } %>

</div>

<% if (outlet) { %>
<script>

const OUTLET_ID = '<%= outlet._id %>';
const IS_LOGGED_IN = <%= typeof user !== 'undefined' && user ? 'true' : 'false' %>;
const USER_ROLE = '<%= typeof user !== "undefined" && user ? user.role : "" %>';
let allMenuItems = [];

function menuCard(item) {
  const addBtn = IS_LOGGED_IN && USER_ROLE === 'student'
    ? `<button onclick="addToCart('${item._id}', this)" ${!item.available ? 'disabled' : ''}
        class="bg-primary text-on-primary px-5 py-2 rounded-full font-bold text-xs shadow-md hover:shadow-lg active:scale-95 transition-all disabled:opacity-50 flex items-center gap-1">
        <span class="material-symbols-outlined text-sm">add</span>Add
      </button>`
    : IS_LOGGED_IN
      ? ''
      : `<a href="/login" class="bg-primary text-on-primary px-5 py-2 rounded-full font-bold text-xs shadow-md">Login to Order</a>`;

  return `
    <div class="bg-white rounded-2xl overflow-hidden shadow-[0_8px_20px_rgba(0,0,0,0.04)] border border-outline-variant/10 hover:shadow-lg transition-shadow group flex flex-col">
      <div class="relative h-48 overflow-hidden bg-primary/5">
        ${item.image
          ? `<img src="${item.image}" alt="${item.name}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"/>`
          : `<div class="w-full h-full flex items-center justify-center"><span class="material-symbols-outlined text-5xl text-primary/20">lunch_dining</span></div>`}
        ${!item.available
          ? `<div class="absolute inset-0 bg-black/50 flex items-center justify-center"><span class="text-white text-xs font-bold bg-black/60 px-3 py-1 rounded-full">Unavailable</span></div>`
          : ''}
      </div>
      <div class="p-4 flex flex-col gap-2 flex-1">
        <div class="flex justify-between items-start">
          <h3 class="font-bold text-base text-on-surface leading-tight flex-1">${item.name}</h3>
          <span class="font-bold text-primary text-base ml-2 flex-shrink-0">₹${item.price}</span>
        </div>
        ${item.description ? `<p class="text-secondary text-sm line-clamp-2 flex-1">${item.description}</p>` : ''}
        <div class="flex justify-between items-center mt-auto pt-2">
          <div class="flex items-center gap-1">
            <span class="material-symbols-outlined text-base text-tertiary-container" style="font-variation-settings:'FILL' 1">star</span>
            <span class="font-bold text-xs">4.5</span>
          </div>
          ${addBtn}
        </div>
      </div>
    </div>`;
}

function renderMenu(items) {
  const avail = items.filter(i => i.available);
  const unavail = items.filter(i => !i.available);

  if (items.length === 0) {
    document.getElementById('menu-available').classList.add('hidden');
    document.getElementById('menu-unavailable').classList.add('hidden');
    document.getElementById('menu-empty').classList.remove('hidden');
    return;
  }
  document.getElementById('menu-empty').classList.add('hidden');

  if (avail.length > 0) {
    document.getElementById('available-count').textContent = avail.length;
    document.getElementById('available-grid').innerHTML = avail.map(menuCard).join('');
    document.getElementById('menu-available').classList.remove('hidden');
  } else {
    document.getElementById('menu-available').classList.add('hidden');
  }

  if (unavail.length > 0) {
    document.getElementById('unavailable-count').textContent = unavail.length;
    document.getElementById('unavailable-grid').innerHTML = unavail.map(menuCard).join('');
    document.getElementById('menu-unavailable').classList.remove('hidden');
  } else {
    document.getElementById('menu-unavailable').classList.add('hidden');
  }
}

function filterMenu(q) {
  const filtered = q
    ? allMenuItems.filter(i => i.name.toLowerCase().includes(q.toLowerCase()))
    : allMenuItems;
  renderMenu(filtered);
}

async function loadMenu() {
  try {
    if (!OUTLET_ID) throw new Error('Outlet ID missing');

    const response = await fetch(`/api/menu/outlet/${OUTLET_ID}`);

    if (!response.ok) throw new Error(`HTTP Error: ${response.status}`);

    const data = await response.json();
    allMenuItems = data.data || data.menu || data || [];
    document.getElementById('menu-loading').remove();
    renderMenu(allMenuItems);

  } catch (error) {
    console.error('MENU ERROR:', error);
    document.getElementById('menu-loading').innerHTML = `
      <div class="col-span-full p-4 bg-red-100 rounded-2xl text-red-500 font-medium flex items-center gap-3">
        <span class="material-symbols-outlined">error</span> Failed to load menu
      </div>`;
  }
}

loadMenu();

</script>
<% } %>

<%- include('../partials/footer') %>