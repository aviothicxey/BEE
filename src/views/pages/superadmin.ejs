<%- include('../partials/head', { title: 'Super Admin' }) %>
<%- include('../partials/navbar') %>

<div class="bg-background min-h-screen pb-32">
  <main class="pt-24 pb-8 px-5 md:px-10 max-w-screen-xl mx-auto">

    <div class="mb-8">
      <div class="flex items-center gap-3 mb-2">
        <span class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center text-primary material-symbols-outlined">admin_panel_settings</span>
        <h1 class="font-extrabold text-3xl text-on-surface tracking-tight">Super Admin</h1>
      </div>
      <p class="text-secondary text-sm">Platform overview and management</p>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      <% [
        { id:'sa-users',   icon:'group',          label:'Total Users',   bg:'bg-blue-50',    text:'text-blue-600' },
        { id:'sa-outlets', icon:'storefront',     label:'Outlets',       bg:'bg-primary/10', text:'text-primary' },
        { id:'sa-orders',  icon:'receipt_long',   label:'Total Orders',  bg:'bg-green-50',   text:'text-green-600' },
        { id:'sa-revenue', icon:'payments',       label:'Revenue (₹)',   bg:'bg-purple-50',  text:'text-purple-600' },
      ].forEach(s => { %>
      <div class="glass-card p-5 rounded-2xl">
        <div class="w-10 h-10 rounded-xl <%= s.bg %> flex items-center justify-center mb-3">
          <span class="material-symbols-outlined <%= s.text %>"><%= s.icon %></span>
        </div>
        <p class="font-extrabold text-2xl text-on-surface" id="<%= s.id %>"><span class="shimmer h-7 w-16 rounded block"></span></p>
        <p class="text-secondary text-xs font-medium mt-1"><%= s.label %></p>
      </div>
      <% }) %>
    </div>

    <!-- Tabs -->
    <div class="flex gap-2 mb-6 border-b border-outline-variant/20">
      <% ['Users', 'Outlets'].forEach((tab, i) => { %>
      <button onclick="switchSATab('<%= tab.toLowerCase() %>')" id="sa-tab-<%= tab.toLowerCase() %>"
        class="px-5 py-3 font-bold text-sm border-b-2 transition-colors <%= i===0 ? 'border-primary text-primary' : 'border-transparent text-secondary hover:text-on-surface' %>">
        <%= tab %>
      </button>
      <% }) %>
    </div>

    <!-- Users Tab -->
    <div id="sa-panel-users">
      <div class="relative mb-4 max-w-xs">
        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-secondary text-lg">search</span>
        <input type="text" id="user-search" oninput="filterUsers(this.value)" placeholder="Search users..."
          class="w-full h-10 pl-10 pr-4 bg-surface-container-low border-none rounded-xl text-sm outline-none focus:ring-2 focus:ring-primary/20 focus:bg-white" />
      </div>
      <div id="users-table" class="space-y-2">
        <% for(let i=0;i<8;i++) { %>
        <div class="bg-white rounded-xl p-4 flex items-center gap-4 border border-outline-variant/10">
          <div class="w-10 h-10 shimmer rounded-full flex-shrink-0"></div>
          <div class="flex-1 space-y-1">
            <div class="h-4 shimmer rounded-full w-1/3"></div>
            <div class="h-3 shimmer rounded-full w-1/2"></div>
          </div>
          <div class="h-8 shimmer rounded-full w-20"></div>
        </div>
        <% } %>
      </div>
    </div>

    <!-- Outlets Tab -->
    <div id="sa-panel-outlets" class="hidden">
      <div id="outlets-sa-table" class="space-y-3">
        <% for(let i=0;i<4;i++) { %>
        <div class="bg-white rounded-2xl p-5 border border-outline-variant/10">
          <div class="flex items-center gap-4">
            <div class="w-16 h-16 shimmer rounded-2xl flex-shrink-0"></div>
            <div class="flex-1 space-y-2">
              <div class="h-5 shimmer rounded-full w-1/3"></div>
              <div class="h-4 shimmer rounded-full w-2/3"></div>
            </div>
            <div class="h-9 shimmer rounded-xl w-24"></div>
          </div>
        </div>
        <% } %>
      </div>
    </div>
  </main>
</div>

<script>
const token = localStorage.getItem('token');
if (!token) window.location.href = '/login';

let allUsers = [];

function switchSATab(tab) {
  ['users','outlets'].forEach(t => {
    document.getElementById(`sa-panel-${t}`).classList.toggle('hidden', t !== tab);
    const btn = document.getElementById(`sa-tab-${t}`);
    btn.className = btn.className.replace(/border-primary text-primary|border-transparent text-secondary hover:text-on-surface/, '');
    btn.classList.add(...(t === tab ? ['border-primary','text-primary'] : ['border-transparent','text-secondary','hover:text-on-surface']));
  });
  if (tab === 'outlets') loadSAOutlets();
}

// Load users
fetch('/api/admin/users', { headers: { 'Authorization': `Bearer ${token}` } })
  .then(r => r.json())
  .then(data => {
    allUsers = data.data || data.users || data || [];
    document.getElementById('sa-users').textContent = allUsers.length;
    renderUsers(allUsers);
  });

// Load stats
Promise.all([
  fetch('/api/outlets/all').then(r=>r.json()),
  fetch('/api/admin/stats/orders-count', { headers: { 'Authorization': `Bearer ${token}` } }).then(r=>r.json()),
  fetch('/api/admin/stats/revenue', { headers: { 'Authorization': `Bearer ${token}` } }).then(r=>r.json()),
]).then(([outlets, orders, revenue]) => {
  document.getElementById('sa-outlets').textContent = (outlets.data||outlets.outlets||outlets||[]).length;
  document.getElementById('sa-orders').textContent = orders.data?.total || orders.total || 0;
  document.getElementById('sa-revenue').textContent = `₹${(revenue.data?.total||revenue.total||0).toLocaleString('en-IN')}`;
});

function filterUsers(q) {
  const filtered = q ? allUsers.filter(u => u.name?.toLowerCase().includes(q.toLowerCase()) || u.email?.toLowerCase().includes(q.toLowerCase())) : allUsers;
  renderUsers(filtered);
}

function renderUsers(users) {
  const roles = { superadmin: 'bg-purple-100 text-purple-700', admin: 'bg-blue-100 text-blue-700', user: 'bg-surface-container text-secondary' };
  document.getElementById('users-table').innerHTML = users.map(u => `
    <div class="bg-white rounded-xl p-4 flex items-center gap-4 border border-outline-variant/10 hover:shadow-sm transition-shadow">
      <div class="w-10 h-10 rounded-full bg-primary-container flex items-center justify-center text-on-primary-container font-bold text-sm flex-shrink-0">
        ${u.name ? u.name[0].toUpperCase() : 'U'}
      </div>
      <div class="flex-1 min-w-0">
        <p class="font-bold text-sm text-on-surface truncate">${u.name || 'Unknown'}</p>
        <p class="text-secondary text-xs truncate">${u.email || ''}</p>
      </div>
      <span class="text-xs font-bold px-2.5 py-1 rounded-full flex-shrink-0 ${roles[u.role] || roles.user}">${u.role || 'user'}</span>
      ${u.isBlocked
        ? `<button onclick="toggleBlock('${u._id}', false)" class="text-xs font-bold px-3 py-1.5 bg-green-50 text-green-600 rounded-lg hover:bg-green-100 transition-colors flex-shrink-0">Unblock</button>`
        : u.role !== 'superadmin'
          ? `<button onclick="toggleBlock('${u._id}', true)" class="text-xs font-bold px-3 py-1.5 bg-error-container text-error rounded-lg hover:bg-error-container/80 transition-colors flex-shrink-0">Block</button>`
          : ''}
    </div>`).join('') || '<div class="text-center py-8 text-secondary text-sm">No users found</div>';
}

async function toggleBlock(userId, block) {
  const res = await fetch(`/api/admin/users/${userId}/block`, {
    method: 'PUT',
    headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
    body: JSON.stringify({ isBlocked: block })
  });
  const data = await res.json();
  if (data.success) {
    showToast(`User ${block ? 'blocked' : 'unblocked'}!`, 'success');
    const u = allUsers.find(u => u._id === userId);
    if (u) u.isBlocked = block;
    renderUsers(allUsers);
  } else showToast('Action failed', 'error');
}

function loadSAOutlets() {
  fetch('/api/outlets/all').then(r=>r.json()).then(data => {
    const outlets = data.data || data.outlets || data || [];
    document.getElementById('outlets-sa-table').innerHTML = outlets.map(o => `
      <div class="bg-white rounded-2xl p-5 border border-outline-variant/10 hover:shadow-sm transition-shadow">
        <div class="flex items-center gap-4">
          <div class="w-16 h-16 rounded-2xl overflow-hidden flex-shrink-0 bg-primary/5">
            ${o.image ? `<img src="${o.image}" class="w-full h-full object-cover"/>` : `<div class="w-full h-full flex items-center justify-center"><span class="material-symbols-outlined text-primary/30 text-2xl">storefront</span></div>`}
          </div>
          <div class="flex-1 min-w-0">
            <p class="font-bold text-base text-on-surface">${o.name}</p>
            <p class="text-secondary text-xs truncate mt-0.5">${o.description || ''}</p>
            <span class="inline-block mt-1 text-[10px] font-bold px-2 py-0.5 rounded-full ${o.isSuspended ? 'bg-error-container text-error' : 'bg-green-100 text-green-700'}">
              ${o.isSuspended ? 'Suspended' : 'Active'}
            </span>
          </div>
          <button onclick="toggleOutlet('${o._id}', ${!o.isSuspended})"
            class="text-xs font-bold px-4 py-2 rounded-xl border transition-colors flex-shrink-0 ${o.isSuspended ? 'border-green-300 text-green-600 hover:bg-green-50' : 'border-error/30 text-error hover:bg-error-container/20'}">
            ${o.isSuspended ? 'Activate' : 'Suspend'}
          </button>
        </div>
      </div>`).join('');
  });
}

async function toggleOutlet(outletId, suspend) {
  const res = await fetch(`/api/admin/outlets/${outletId}/suspend`, {
    method: 'PUT',
    headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
    body: JSON.stringify({ isSuspended: suspend })
  });
  const data = await res.json();
  if (data.success) { showToast(`Outlet ${suspend ? 'suspended' : 'activated'}!`, 'success'); loadSAOutlets(); }
  else showToast('Action failed', 'error');
}
</script>

<%- include('../partials/footer') %>
