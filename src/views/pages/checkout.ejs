<%- include('../partials/head', { title: 'Checkout' }) %>
<%- include('../partials/navbar') %>

<div class="bg-background min-h-screen pb-32">
  <main class="pt-24 pb-8 px-5 md:px-10 max-w-2xl mx-auto">
    <div class="mb-6">
      <h1 class="font-extrabold text-3xl text-on-surface tracking-tight">Checkout</h1>
      <p class="text-secondary text-sm mt-1">Review your order before placing</p>
    </div>

    <!-- Cart items -->
    <div class="glass-card rounded-3xl p-6 mb-5">
      <h2 class="font-bold text-base text-on-surface mb-4 flex items-center gap-2">
        <span class="material-symbols-outlined text-primary">shopping_bag</span>
        Your Items
      </h2>
      <div id="checkout-items" class="space-y-3">
        <div class="h-14 shimmer rounded-xl"></div>
        <div class="h-14 shimmer rounded-xl"></div>
        <div class="h-14 shimmer rounded-xl"></div>
      </div>
      <div class="border-t border-outline-variant/20 mt-4 pt-4 space-y-2">
        <div class="flex justify-between text-sm text-secondary font-medium">
          <span>Subtotal</span>
          <span id="checkout-subtotal">₹0</span>
        </div>
        <div class="flex justify-between text-sm text-secondary font-medium">
          <span>GST (5%)</span>
          <span id="checkout-gst">₹0</span>
        </div>
        <div class="flex justify-between text-sm text-secondary font-medium">
          <span>Pickup fee</span>
          <span class="text-green-600 font-bold">FREE</span>
        </div>
        <div class="flex justify-between font-bold text-on-surface text-lg border-t border-outline-variant/20 pt-2 mt-1">
          <span>Total</span>
          <span id="checkout-total" class="text-primary">₹0</span>
        </div>
      </div>
    </div>

    <!-- Payment method -->
    <div class="glass-card rounded-3xl p-6 mb-5">
      <h2 class="font-bold text-base text-on-surface mb-4 flex items-center gap-2">
        <span class="material-symbols-outlined text-primary">payments</span>
        Payment Method
      </h2>
      <div class="space-y-3">
        <label class="flex items-center gap-4 p-4 rounded-2xl border border-outline-variant/30 hover:border-primary/40 cursor-pointer transition-colors has-[:checked]:border-primary has-[:checked]:bg-primary/5">
          <input type="radio" name="payment" value="COD" class="accent-primary" checked />
          <span class="font-bold text-sm text-on-surface">Pay at Pickup</span>
        </label>
        <label class="flex items-center gap-4 p-4 rounded-2xl border border-outline-variant/30 hover:border-primary/40 cursor-pointer transition-colors has-[:checked]:border-primary has-[:checked]:bg-primary/5">
          <input type="radio" name="payment" value="ONLINE" class="accent-primary" />
          <span class="font-bold text-sm text-on-surface">Online Payment</span>
        </label>
      </div>
    </div>

    <!-- Place Order -->
    <button onclick="placeOrder()" id="place-order-btn"
      class="w-full h-14 bg-primary text-on-primary font-bold rounded-2xl shadow-[0_4px_16px_rgba(153,71,0,0.3)] hover:-translate-y-0.5 active:scale-95 transition-all flex items-center justify-center gap-2 text-base">
      <span class="material-symbols-outlined">check_circle</span>
      Place Order
    </button>
  </main>
</div>

<script>
let cartData = null;

fetch('/api/cart', { credentials: 'include' })
  .then(r => r.json())
  .then(data => {
    cartData = data.data || data.cart || data || {};
    const items = cartData.items || [];
    const container = document.getElementById('checkout-items');

    if (items.length === 0) {
      container.innerHTML = '<p class="text-secondary text-sm text-center py-4">Your cart is empty. <a href="/outlets" class="text-primary font-bold hover:underline">Browse outlets</a></p>';
      document.getElementById('place-order-btn').disabled = true;
      return;
    }

    let subtotal = 0;
    container.innerHTML = items.map(item => {
      const sub = (item.price || 0) * (item.quantity || 1);
      subtotal += sub;
      return `<div class="flex items-center gap-3 py-2">
        <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center flex-shrink-0">
          ${item.image ? `<img src="${item.image}" class="w-10 h-10 rounded-xl object-cover"/>` : `<span class="material-symbols-outlined text-primary/40 text-sm">lunch_dining</span>`}
        </div>
        <div class="flex-1">
          <p class="font-bold text-sm text-on-surface">${item.name || 'Item'}</p>
          <p class="text-secondary text-xs">×${item.quantity || 1} · ₹${item.price || 0} each</p>
        </div>
        <span class="font-bold text-sm text-primary">₹${sub}</span>
      </div>`;
    }).join('');

    const gst = Math.round(subtotal * 0.05);
    const total = subtotal + gst;
    document.getElementById('checkout-subtotal').textContent = `₹${subtotal}`;
    document.getElementById('checkout-gst').textContent = `₹${gst}`;
    document.getElementById('checkout-total').textContent = `₹${total}`;
  })
  .catch(() => {
    document.getElementById('checkout-items').innerHTML = '<p class="text-error text-sm text-center py-4">Failed to load cart.</p>';
  });

async function placeOrder() {
  const btn = document.getElementById('place-order-btn');
  btn.disabled = true;
  btn.innerHTML = '<div class="w-5 h-5 border-2 border-on-primary border-t-transparent rounded-full animate-spin"></div> Placing Order...';

  try {
    const paymentMethod = document.querySelector('input[name="payment"]:checked')?.value || 'COD';
    const res = await fetch('/api/orders/create', {
      method: 'POST',
      credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ paymentMethod })
    });
    const data = await res.json();
    if (data.success) {
      // Clear cart in navbar sidebar
      if (typeof renderCart === 'function') renderCart({ items: [] });
      window.location.href = `/order/${data.data?._id || data.order?._id}?success=1`;
    } else {
      showToast(data.message || 'Failed to place order', 'error');
      btn.disabled = false;
      btn.innerHTML = '<span class="material-symbols-outlined">check_circle</span> Place Order';
    }
  } catch {
    showToast('Error placing order', 'error');
    btn.disabled = false;
    btn.innerHTML = '<span class="material-symbols-outlined">check_circle</span> Place Order';
  }
}
</script>

<%- include('../partials/footer') %>
