<%- include('../partials/head', { title: searchQuery ? `Search: ${searchQuery}` : 'Search' }) %>
<%- include('../partials/navbar') %>

<div class="bg-background min-h-screen pb-32">
  <main class="pt-24 pb-8 px-5 md:px-10 max-w-screen-xl mx-auto">

    <!-- Search header -->
    <form action="/search" method="GET" class="mb-6">
      <div class="relative max-w-2xl">
        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-secondary text-xl">search</span>
        <input name="q" value="<%= searchQuery || '' %>"
          class="w-full h-14 pl-12 pr-14 bg-white border border-outline-variant/30 rounded-2xl text-base font-medium focus:ring-2 focus:ring-primary/20 focus:border-primary/40 outline-none shadow-sm"
          placeholder="Search food, outlets..." />
        <% if (searchQuery) { %>
        <a href="/search" class="absolute right-4 top-1/2 -translate-y-1/2 w-8 h-8 rounded-full hover:bg-surface-container-high flex items-center justify-center">
          <span class="material-symbols-outlined text-secondary text-sm">close</span>
        </a>
        <% } %>
      </div>
      <% if (searchQuery) { %>
      <p class="text-secondary text-sm mt-3">
        Results for "<strong class="text-on-surface"><%= searchQuery %></strong>"
      </p>
      <% } %>
    </form>

    <!-- Results -->
    <div id="search-loading" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
      <% for(let i=0;i<8;i++) { %>
      <div class="bg-white rounded-2xl overflow-hidden border border-outline-variant/10">
        <div class="h-48 shimmer"></div>
        <div class="p-4 space-y-2">
          <div class="h-4 shimmer rounded-full w-3/4"></div>
          <div class="h-3 shimmer rounded-full w-1/2"></div>
          <div class="h-6 shimmer rounded-full w-1/3 mt-3"></div>
        </div>
      </div>
      <% } %>
    </div>

    <!-- Outlets section -->
    <div id="outlets-section" class="hidden mb-10">
      <h2 class="font-bold text-base text-on-surface-variant uppercase tracking-wider mb-4">Outlets · <span id="outlets-count">0</span></h2>
      <div id="outlets-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5"></div>
    </div>

    <!-- Menu items section -->
    <div id="menu-section" class="hidden">
      <h2 class="font-bold text-base text-on-surface-variant uppercase tracking-wider mb-4">Menu Items · <span id="menu-count">0</span></h2>
      <div id="menu-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5"></div>
    </div>

    <!-- Empty -->
    <div id="search-empty" class="hidden text-center py-20">
      <div class="w-20 h-20 bg-primary/5 rounded-full flex items-center justify-center mx-auto mb-4">
        <span class="material-symbols-outlined text-4xl text-primary/30">search_off</span>
      </div>
      <p class="font-bold text-on-surface">No results for "<%= searchQuery %>"</p>
      <a href="/search" class="mt-3 text-primary font-bold text-sm hover:underline block">Clear search</a>
    </div>
  </main>
</div>

<script>
const Q = '<%= (searchQuery || "").replace(/'/g, "\\'") %>';
const IS_LOGGED_IN = <%= typeof user !== 'undefined' && user ? 'true' : 'false' %>;
const USER_ROLE = '<%= typeof user !== "undefined" && user ? user.role : "" %>';

function outletCard(o) {
  return `<a href="/outlet/${o._id}" class="group cursor-pointer bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1 border border-outline-variant/5 block">
    <div class="relative h-40 overflow-hidden">
      ${o.image ? `<img src="${o.image}" alt="${o.name}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"/>` : `<div class="w-full h-full bg-gradient-to-br from-primary/10 to-tertiary/10 flex items-center justify-center"><span class="material-symbols-outlined text-5xl text-primary/20">storefront</span></div>`}
      <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
      <div class="absolute top-3 right-3 text-[10px] font-bold px-2.5 py-1 rounded-full ${o.isSuspended ? 'bg-error/80 text-white' : 'bg-green-500/90 text-white'}">${o.isSuspended ? 'Closed' : 'Open'}</div>
    </div>
    <div class="p-4">
      <h4 class="font-bold text-base text-on-surface group-hover:text-primary transition-colors">${o.name}</h4>
      ${o.description ? `<p class="text-secondary text-xs mt-0.5 line-clamp-1">${o.description}</p>` : ''}
      <div class="flex items-center gap-1.5 mt-2">
        <span class="material-symbols-outlined text-primary text-sm">schedule</span>
        <span class="font-bold text-xs text-primary">${o.timing || '10-15 min'}</span>
      </div>
    </div>
  </a>`;
}

function menuItemCard(item) {
  const addBtn = IS_LOGGED_IN && USER_ROLE === 'user'
    ? `<button onclick="event.preventDefault();addToCartFromSearch('${item._id}','${item.outlet}',this)" ${!item.available ? 'disabled' : ''}
        class="bg-primary text-on-primary px-4 py-1.5 rounded-full font-bold text-xs shadow-md hover:shadow-lg active:scale-95 transition-all disabled:opacity-40 flex items-center gap-1">
        <span class="material-symbols-outlined text-sm">add</span>Add
      </button>`
    : IS_LOGGED_IN
      ? ''
      : `<a href="/login" onclick="event.stopPropagation()" class="bg-primary text-on-primary px-4 py-1.5 rounded-full font-bold text-xs shadow-md">Login to Order</a>`;

  return `<a href="/outlet/${item.outlet}" class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow group flex flex-col block">
    <div class="relative h-40 overflow-hidden bg-primary/5">
      ${item.image ? `<img src="${item.image}" alt="${item.name}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"/>` : `<div class="w-full h-full flex items-center justify-center"><span class="material-symbols-outlined text-5xl text-primary/20">lunch_dining</span></div>`}
      ${!item.available ? `<div class="absolute inset-0 bg-black/40 flex items-center justify-center"><span class="text-white text-xs font-bold">Unavailable</span></div>` : ''}
    </div>
    <div class="p-4 flex flex-col gap-2 flex-1">
      <div class="flex justify-between items-start">
        <h3 class="font-bold text-sm text-on-surface leading-tight flex-1">${item.name}</h3>
        <span class="font-bold text-primary text-sm ml-2">₹${item.price}</span>
      </div>
      ${item.description ? `<p class="text-secondary text-xs line-clamp-2">${item.description}</p>` : ''}
      <div class="flex justify-end items-center mt-auto pt-1">${addBtn}</div>
    </div>
  </a>`;
}

async function addToCartFromSearch(menuItemId, outletId, btn) {
  const token = localStorage.getItem('token');
  btn.disabled = true;
  btn.innerHTML = '<div class="w-3 h-3 border-2 border-on-primary border-t-transparent rounded-full animate-spin"></div>';
  try {
    const r = await fetch('/api/cart/add', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
      credentials: 'include',
      body: JSON.stringify({ menuItemId, quantity: 1, outletId })
    });
    const data = await r.json();
    if (data.success !== false) {
      btn.innerHTML = '<span class="material-symbols-outlined text-sm">check</span>Added';
      if (typeof loadCart === 'function') loadCart();
      setTimeout(() => { btn.innerHTML = '<span class="material-symbols-outlined text-sm">add</span>Add'; btn.disabled = false; }, 1500);
    } else {
      showToast(data.message || 'Could not add to cart', 'error');
      btn.innerHTML = '<span class="material-symbols-outlined text-sm">add</span>Add'; btn.disabled = false;
    }
  } catch { btn.innerHTML = '<span class="material-symbols-outlined text-sm">add</span>Add'; btn.disabled = false; }
}

Promise.all([
  fetch('/api/outlets/all').then(r=>r.json()),
  Q ? fetch(`/api/menu/search?q=${encodeURIComponent(Q)}`).then(r=>r.json()) : Promise.resolve({ data: [] })
]).then(([outletData, menuData]) => {
  document.getElementById('search-loading').remove();
  const allOutlets = outletData.data || outletData.outlets || outletData || [];
  // Filter: match name/description AND exclude suspended outlets
  const outlets = Q
    ? allOutlets.filter(o => !o.isSuspended && (o.name?.toLowerCase().includes(Q.toLowerCase()) || o.description?.toLowerCase().includes(Q.toLowerCase())))
    : allOutlets.filter(o => !o.isSuspended);
  const menuItems = (menuData.data || menuData.items || menuData || []).filter(i => i.available);
  const unavailableItems = (menuData.data || menuData.items || menuData || []).filter(i => !i.available);

  if (outlets.length === 0 && menuItems.length === 0 && unavailableItems.length === 0) {
    document.getElementById('search-empty').classList.remove('hidden');
    return;
  }

  if (outlets.length > 0) {
    document.getElementById('outlets-count').textContent = outlets.length;
    document.getElementById('outlets-grid').innerHTML = outlets.map(outletCard).join('');
    document.getElementById('outlets-section').classList.remove('hidden');
  }
  if (menuItems.length > 0) {
    document.getElementById('menu-count').textContent = menuItems.length;
    document.getElementById('menu-grid').innerHTML = menuItems.map(menuItemCard).join('');
    document.getElementById('menu-section').classList.remove('hidden');
  }
}).catch(() => {
  document.getElementById('search-loading').innerHTML = '<div class="col-span-full p-4 bg-error-container/20 rounded-2xl text-error text-sm font-medium flex items-center gap-3"><span class="material-symbols-outlined">error</span>Search failed</div>';
});
</script>

<%- include('../partials/footer') %>
