<%- include('../partials/head', { title: 'Order Ahead, Skip the Queue' }) %>

<%- include('../partials/navbar') %>

<div class="min-h-screen overflow-x-hidden">

  <!-- ── HERO ── -->
  <section class="relative min-h-[751px] flex flex-col justify-center items-center px-5 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <div class="w-full h-full bg-gradient-to-br from-[rgba(153,71,0,0.04)] via-background to-[rgba(144,77,0,0.04)]"></div>
      <div class="absolute top-1/3 -left-20 w-72 h-72 bg-primary/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-1/3 -right-20 w-64 h-64 bg-tertiary/10 rounded-full blur-3xl"></div>
    </div>

    <div class="relative z-10 text-center max-w-4xl mx-auto space-y-6">
      <div class="inline-flex items-center gap-2 bg-[rgba(153,71,0,0.08)] px-4 py-1.5 rounded-full border border-[rgba(153,71,0,0.15)]">
        <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
        <span class="text-primary font-bold text-xs">LIVE: Popular Outlets Open Now</span>
      </div>

      <h1 class="font-extrabold text-5xl md:text-[56px] text-on-surface leading-tight px-4" style="letter-spacing:-1px">
        Order ahead, <br/>
        <span class="text-primary italic">skip the queue</span>
      </h1>

      <p class="text-secondary text-lg max-w-xl mx-auto px-4 leading-relaxed">
        Get your favorite campus meals ready for pickup. No more waiting between lectures.
      </p>

      <!-- Search bar -->
      <div class="max-w-2xl mx-auto w-full px-4 pt-2">
        <form action="/search" method="GET">
          <div class="glass-card p-2 rounded-full flex items-center shadow-xl border border-[rgba(224,192,175,0.3)]">
            <span class="material-symbols-outlined ml-4 text-secondary">search</span>
            <input name="q" class="flex-1 bg-transparent border-none focus:outline-none focus:ring-0 px-4 py-3 text-on-surface text-sm font-medium placeholder:text-secondary/50"
              placeholder="Search for burgers, rolls, or your favourite outlet..." />
            <button type="submit" class="bg-primary text-on-primary px-7 py-3 rounded-full font-bold text-sm shadow-md hover:-translate-y-0.5 active:scale-95 transition-all flex-shrink-0">
              Find Food
            </button>
          </div>
        </form>
      </div>

      <!-- Animated food tags -->
      <div class="flex flex-wrap justify-center gap-3 pt-2 px-4">
        <% const tags = [
          { icon: 'lunch_dining', label: 'Fresh Burgers', color: 'text-primary', query: 'burger', dur: '3s', delay: '0s' },
          { icon: 'local_pizza',  label: 'Pizza',         color: 'text-tertiary', query: 'pizza',  dur: '2.5s', delay: '0.2s' },
          { icon: 'coffee',       label: 'Coffee',        color: 'text-secondary',query: 'coffee', dur: '3.2s', delay: '0.5s' },
          { icon: 'ramen_dining', label: 'Hot Noodles',   color: 'text-primary',  query: 'noodles',dur: '2.8s', delay: '0.8s' },
        ]; %>
        <% tags.forEach(t => { %>
        <a href="/search?q=<%= encodeURIComponent(t.query) %>"
          class="glass-card px-5 py-2.5 rounded-full flex items-center gap-2.5 border border-[rgba(153,71,0,0.1)] shadow-sm hover:scale-105 transition-transform cursor-pointer animate-bounce"
          style="animation-duration:<%= t.dur %>;animation-delay:<%= t.delay %>">
          <span class="material-symbols-outlined icon-accent <%= t.color %>"><%= t.icon %></span>
          <span class="font-bold text-xs text-on-surface"><%= t.label %></span>
        </a>
        <% }) %>
      </div>
    </div>
  </section>

  <!-- ── FEATURES BENTO ── -->
  <section class="py-12 px-5 md:px-10 bg-surface-container-low/50">
    <div class="max-w-screen-xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-5">
      <% [
        { icon:'bolt',       title:'Fast Pickup',    desc:'Ready in 10 minutes. Skip the line and grab your meal on the way to class.', color:'text-white',   bg:'bg-primary', lightBg:'bg-primary/15' },
        { icon:'location_on',title:'Live Tracking',  desc:'Know exactly when your order is prepped and ready for hand-off.',            color:'text-white',  bg:'bg-tertiary', lightBg:'bg-tertiary/15' },
        { icon:'payments',   title:'Easy Pay',       desc:'Pay with student wallet, UPI, or cards seamlessly within the app.',          color:'text-white', bg:'bg-secondary', lightBg:'bg-secondary/15' },
      ].forEach(f => { %>
      <div class="glass-card p-6 rounded-3xl flex flex-col items-center text-center gap-4 hover:shadow-xl transition-all duration-300 group border-2 border-transparent hover:border-primary/20">
        <div class="w-16 h-16 rounded-2xl <%= f.bg %> flex items-center justify-center group-hover:scale-110 transition-transform shadow-sm">
          <span class="material-symbols-outlined text-white text-3xl"><%= f.icon %></span>
        </div>
        <h3 class="font-bold text-xl text-on-surface"><%= f.title %></h3>
        <p class="text-secondary text-sm leading-relaxed"><%= f.desc %></p>
      </div>
      <% }) %>
    </div>
  </section>

  <!-- ── POPULAR OUTLETS ── -->
  <section class="py-12 px-5 md:px-10 max-w-screen-xl mx-auto overflow-hidden">
    <div class="flex justify-between items-end mb-6 px-1">
      <div class="space-y-1">
        <h2 class="font-bold text-3xl md:text-4xl text-on-surface">Popular Outlets</h2>
        <p class="text-secondary text-sm">Campus favourites ranked by orders</p>
      </div>
      <a href="/outlets" class="text-primary font-bold text-sm hover:underline flex items-center gap-1">
        View all <span class="material-symbols-outlined text-base">arrow_forward</span>
      </a>
    </div>

    <div id="popular-outlets-container" class="flex gap-4 overflow-x-auto no-scrollbar pb-6 snap-x px-1">
      <!-- skeleton -->
      <% for(let i=0;i<4;i++) { %>
      <div class="snap-start min-w-[280px] md:min-w-[320px] outlet-skeleton">
        <div class="h-48 shimmer rounded-3xl mb-4"></div>
        <div class="h-5 shimmer rounded-full w-2/3 mb-2"></div>
        <div class="h-4 shimmer rounded-full w-1/2"></div>
      </div>
      <% } %>
    </div>
  </section>

  <!-- ── TRENDING TODAY ── -->
  <section class="py-12 px-5 md:px-10 bg-surface-container-low/30">
    <div class="max-w-screen-xl mx-auto">
      <div class="mb-6 px-1">
        <h2 class="font-bold text-3xl text-on-surface">Trending Today</h2>
        <p class="text-secondary text-sm">The most ordered categories this week</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 px-1">
        <% [
          { icon:'local_pizza', label:'Pizza',   query:'pizza',   badge:'Best Seller', badgeBg:'bg-tertiary text-white' },
          { icon:'lunch_dining',label:'Burgers', query:'burger',  badge:'Must Try',    badgeBg:'bg-primary text-on-primary' },
          { icon:'coffee',      label:'Coffee',  query:'coffee',  badge:null,          badgeBg:'' },
          { icon:'icecream',    label:'Desserts',query:'desserts',badge:'New',          badgeBg:'bg-secondary text-white' },
        ].forEach(cat => { %>
        <a href="/search?q=<%= encodeURIComponent(cat.query) %>"
          class="glass-card rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 group cursor-pointer block hover:border-primary/40 border-2 border-transparent">
          <div class="relative h-36 flex items-center justify-center overflow-hidden">
            <div class="w-20 h-20 rounded-full bg-primary\/10 flex items-center justify-center shadow-sm transition-all duration-300 group-hover:bg-primary\/20">
              <span class="material-symbols-outlined icon-accent text-5xl group-hover:scale-110 transition-all duration-300"><%= cat.icon %></span>
            </div>
            <% if(cat.badge) { %>
            <span class="absolute top-3 left-3 <%= cat.badgeBg %> font-bold text-[10px] px-3 py-1 rounded-full uppercase tracking-wider shadow-md"><%= cat.badge %></span>
            <% } %>
          </div>
          <div class="p-4 flex justify-between items-center">
            <h5 class="font-bold text-base text-on-surface"><%= cat.label %></h5>
            <span class="w-8 h-8 rounded-full bg-primary text-white hover:bg-tertiary transition-all flex items-center justify-center shadow-sm">
              <span class="material-symbols-outlined text-sm">arrow_forward</span>
            </span>
          </div>
        </a>
        <% }) %>
      </div>
    </div>
  </section>

  <!-- ── TESTIMONIALS ── -->
  <section class="py-12 px-5 md:px-10 overflow-hidden">
    <div class="max-w-screen-xl mx-auto">
      <div class="text-center mb-10">
        <h2 class="font-bold text-3xl text-on-surface">Student Voices</h2>
        <p class="text-secondary text-sm mt-2">Why thousands of students trust CampusBites</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        <% [
          { name:'Aanya Sharma', role:'CS Undergraduate',    rating:5, text:'Saved me during exams. The live tracking is super accurate and the food is always hot when I pick it up!', border:'border-primary', bg:'bg-primary/5' },
          { name:'Rohan Verma',  role:'MBA Student',         rating:4, text:'Best food-tech app on campus. The interface is sleek and ordering takes literally 10 seconds.',            border:'border-tertiary', bg:'bg-tertiary/5' },
          { name:'Sneha Kapoor', role:'Final Year Biotech',  rating:5, text:'The skip the queue feature is a lifesaver. No more missing the first 10 mins of my 2 PM lecture.',         border:'border-secondary', bg:'bg-secondary/5' },
        ].forEach(t => { %>
        <div class="glass-card p-6 rounded-3xl space-y-4 border-l-4 <%= t.border %> shadow-md hover:shadow-lg transition-all <%= t.bg %>">
          <div class="flex gap-0.5">
            <% for(let i=1;i<=5;i++) { %>
            <span class="material-symbols-outlined text-sm text-tertiary" style="font-variation-settings:'FILL' <%= i<=t.rating ? 1 : 0 %>">star</span>
            <% } %>
          </div>
          <p class="text-on-surface text-sm italic leading-relaxed font-medium">"<%= t.text %>"</p>
          <div class="flex items-center gap-3 pt-2">
            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-primary to-tertiary flex items-center justify-center font-bold text-white text-xs shadow-sm">
              <%= t.name[0] %>
            </div>
            <div>
              <p class="font-bold text-xs text-on-surface"><%= t.name %></p>
              <p class="text-secondary text-[10px]"><%= t.role %></p>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
  </section>

  <!-- ── CTA ── -->
  <section class="py-10 px-5 md:px-10">
    <div class="max-w-screen-xl mx-auto bg-primary rounded-[2.5rem] p-12 md:p-20 text-center text-on-primary overflow-hidden relative group">
      <div class="absolute inset-0 bg-white/5 opacity-0 group-hover:opacity-100 transition-opacity"></div>
      <div class="absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-full -translate-y-1/2 translate-x-1/2"></div>
      <div class="absolute bottom-0 left-0 w-48 h-48 bg-white/5 rounded-full translate-y-1/2 -translate-x-1/2"></div>
      <div class="relative z-10 space-y-6">
        <h2 class="font-extrabold text-4xl md:text-5xl">Hungry? Don't wait.</h2>
        <p class="text-on-primary/90 text-lg max-w-lg mx-auto">Join 5,000+ students already skipping the queue every day.</p>
        <div class="flex flex-col sm:flex-row justify-center items-center gap-4 pt-2">
          <% if (typeof user !== 'undefined' && user) { %>
          <a href="/outlets" class="bg-white text-primary px-10 py-4 rounded-full font-extrabold text-base shadow-xl hover:scale-105 active:scale-95 transition-transform">
            Order Now
          </a>
          <% } else { %>
          <a href="/signup" class="bg-white text-primary px-10 py-4 rounded-full font-extrabold text-base shadow-xl hover:scale-105 active:scale-95 transition-transform">
            Register Now — It's Free
          </a>
          <% } %>
          <a href="/outlets" class="bg-transparent border-2 border-white/30 text-white px-10 py-4 rounded-full font-bold text-base hover:bg-white/10 transition-all">
            Browse Outlets
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── FOOTER ── -->
  <footer class="hidden md:block py-16 bg-surface-container px-10 mt-4">
    <div class="max-w-screen-xl mx-auto grid grid-cols-4 gap-8">
      <div class="col-span-2 space-y-4">
        <span class="font-extrabold text-xl text-primary tracking-tight">CampusBites</span>
        <p class="text-secondary text-sm max-w-sm leading-relaxed">Elevating the campus dining experience with modern tech, live tracking, and seamless payments.</p>
        <div class="flex gap-3">
          <span class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary material-symbols-outlined cursor-pointer hover:bg-primary/20 transition-colors">public</span>
          <span class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary material-symbols-outlined cursor-pointer hover:bg-primary/20 transition-colors">mail</span>
        </div>
      </div>
      <div class="space-y-4">
        <h6 class="font-bold text-xs text-on-surface uppercase tracking-widest">Company</h6>
        <ul class="space-y-2 text-secondary text-sm">
          <li class="hover:text-primary cursor-pointer transition-colors">About Us</li>
          <li class="hover:text-primary cursor-pointer transition-colors">Partners</li>
          <li class="hover:text-primary cursor-pointer transition-colors">Contact</li>
        </ul>
      </div>
      <div class="space-y-4">
        <h6 class="font-bold text-xs text-on-surface uppercase tracking-widest">Support</h6>
        <ul class="space-y-2 text-secondary text-sm">
          <li class="hover:text-primary cursor-pointer transition-colors">Help Center</li>
          <li class="hover:text-primary cursor-pointer transition-colors">Safety</li>
          <li class="hover:text-primary cursor-pointer transition-colors">Refunds</li>
        </ul>
      </div>
    </div>
    <div class="max-w-screen-xl mx-auto border-t border-outline-variant/30 mt-12 pt-8 flex justify-between text-xs text-secondary">
      <p>© 2025 CampusBites. All rights reserved.</p>
      <div class="flex gap-6">
        <span class="hover:text-primary cursor-pointer">Privacy Policy</span>
        <span class="hover:text-primary cursor-pointer">Terms of Service</span>
      </div>
    </div>
  </footer>

  <div class="md:hidden h-20"></div>
</div>

<script>
// Load popular outlets via API
fetch('/api/outlets/popular?limit=4', { credentials: 'include' })
  .then(r => r.json())
  .then(data => {
    const outlets = data.data || [];
    const container = document.getElementById('popular-outlets-container');
    container.querySelectorAll('.outlet-skeleton').forEach(el => el.remove());
    if (outlets.length === 0) {
      container.innerHTML = '<p class="text-secondary text-sm py-12 w-full text-center">No outlets yet</p>';
      return;
    }
    outlets.forEach(o => {
      container.innerHTML += `
        <a href="/outlet/${o._id}" class="snap-start min-w-[280px] md:min-w-[320px] group cursor-pointer block">
          <div class="relative h-48 rounded-3xl overflow-hidden mb-4 shadow-md">
            ${o.image
              ? `<img src="${o.image}" alt="${o.name}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"/>`
              : `<div class="w-full h-full bg-gradient-to-br from-primary/15 to-tertiary/10 flex items-center justify-center"><span class="material-symbols-outlined text-6xl text-primary/20">storefront</span></div>`}
            <div class="absolute top-4 right-4 bg-white/90 backdrop-blur-md px-3 py-1 rounded-full flex items-center gap-1 shadow-sm">
              <span class="material-symbols-outlined text-sm text-tertiary-container" style="font-variation-settings:'FILL' 1">star</span>
              <span class="font-bold text-xs text-on-surface">4.8</span>
            </div>
            ${!o.isSuspended ? `<div class="absolute bottom-3 left-3 glass-tag px-2.5 py-1 rounded-full flex items-center gap-1"><span class="w-1.5 h-1.5 rounded-full bg-green-500"></span><span class="font-bold text-[10px] text-on-surface">Open</span></div>` : ''}
          </div>
          <h4 class="font-bold text-lg text-on-surface group-hover:text-primary transition-colors">${o.name}</h4>
          <p class="text-secondary text-sm mt-0.5 line-clamp-1">${o.description || 'Campus Outlet'}</p>
          <div class="flex items-center gap-2 mt-2">
            <span class="material-symbols-outlined text-primary text-base">schedule</span>
            <span class="font-bold text-xs text-primary">${o.timing || '10-15 min'}</span>
          </div>
        </a>`;
    });
  })
  .catch(() => {});
</script>

<%- include('../partials/footer') %>
