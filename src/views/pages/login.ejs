<%- include('../partials/head', { title: 'Login' }) %>

<div class="bg-background font-sans text-on-background min-h-screen flex flex-col items-center justify-center relative overflow-hidden">
  <!-- Background blobs -->
  <div class="absolute inset-0 pointer-events-none opacity-40">
    <div class="absolute top-1/4 -left-20 w-80 h-80 bg-primary/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 -right-20 w-64 h-64 bg-tertiary/10 rounded-full blur-3xl"></div>
  </div>

  <!-- Top nav -->
  <nav class="fixed top-0 w-full z-50 flex justify-between items-center px-5 md:px-10 h-16 bg-surface/70 backdrop-blur-xl border-b border-outline-variant/20 shadow-[0_8px_32px_rgba(0,0,0,0.04)]">
    <a href="/" class="font-extrabold text-xl text-primary tracking-tight">CampusBites</a>
    <a href="/signup" class="font-bold text-sm text-secondary hover:text-primary transition-colors">
      New here? <span class="text-primary">Sign Up</span>
    </a>
  </nav>

  <main class="relative z-10 w-full max-w-[440px] px-5 mt-16">
    <% if (typeof error !== 'undefined' && error) { %>
    <div class="mb-4 p-4 bg-error-container/20 rounded-2xl flex items-center gap-3 text-error text-sm font-medium">
      <span class="material-symbols-outlined">error</span> <%= error %>
    </div>
    <% } %>

    <div class="glass-panel p-8 md:p-10 rounded-[32px] shadow-[0_20px_40px_rgba(0,0,0,0.04)] flex flex-col gap-6">
      <div class="space-y-1 text-center">
        <h1 class="font-bold text-3xl text-on-surface tracking-tight">Welcome back!</h1>
        <p class="text-secondary text-sm">Fuel your study sessions with ease.</p>
      </div>

      <form action="/auth/login" method="POST" class="flex flex-col gap-4" id="login-form">
        <!-- Email -->
        <div class="flex flex-col gap-1">
          <label class="font-bold text-xs text-on-surface-variant ml-4 uppercase tracking-wider">Email Address</label>
          <div class="relative group">
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline group-focus-within:text-primary transition-colors text-xl">mail</span>
            <input type="email" name="email" required value="<%= typeof formData !== 'undefined' ? formData.email || '' : '' %>"
              class="w-full h-14 pl-12 pr-4 bg-[#F1F3F5] border-none rounded-2xl focus:ring-2 focus:ring-primary/20 focus:bg-white transition-all text-sm font-medium outline-none"
              placeholder="student@university.edu" />
          </div>
        </div>

        <!-- Password -->
        <div class="flex flex-col gap-1">
          <label class="font-bold text-xs text-on-surface-variant ml-4 uppercase tracking-wider">Password</label>
          <div class="relative group">
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline group-focus-within:text-primary transition-colors text-xl">lock</span>
            <input type="password" name="password" id="password-input" required
              class="w-full h-14 pl-12 pr-12 bg-[#F1F3F5] border-none rounded-2xl focus:ring-2 focus:ring-primary/20 focus:bg-white transition-all text-sm font-medium outline-none"
              placeholder="••••••••" />
            <button type="button" onclick="togglePassword('password-input', this)"
              class="absolute right-4 top-1/2 -translate-y-1/2 text-outline hover:text-secondary transition-colors">
              <span class="material-symbols-outlined text-xl">visibility</span>
            </button>
          </div>
        </div>

        <div class="flex justify-end px-1">
          <button type="button" class="font-bold text-xs text-primary hover:text-tertiary transition-colors">Forgot password?</button>
        </div>

        <button type="submit" id="login-btn"
          class="w-full h-14 bg-primary text-on-primary font-bold rounded-2xl shadow-[0_4px_12px_rgba(29,94,143,0.22)] hover:shadow-[0_8px_20px_rgba(29,94,143,0.32)] hover:-translate-y-0.5 active:scale-95 transition-all flex items-center justify-center gap-2">
          Login <span class="material-symbols-outlined">arrow_forward</span>
        </button>
      </form>

      <div class="flex items-center gap-4">
        <div class="h-px flex-1 bg-outline-variant/30"></div>
        <span class="text-secondary font-bold text-xs uppercase tracking-wider">or</span>
        <div class="h-px flex-1 bg-outline-variant/30"></div>
      </div>

      <a href="/api/auth/google"
        class="w-full h-14 border-[1.5px] border-outline-variant/50 rounded-2xl flex items-center justify-center gap-3 hover:bg-surface-container-low transition-colors group active:scale-95">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        <span class="font-medium text-on-surface-variant group-hover:text-on-surface text-sm">Continue with Google</span>
      </a>

      <p class="text-center text-secondary text-xs">
        Don't have an account? <a href="/signup" class="text-primary font-bold hover:underline">Sign Up</a>
      </p>
    </div>
  </main>
</div>

<%- include('../partials/footer') %>
